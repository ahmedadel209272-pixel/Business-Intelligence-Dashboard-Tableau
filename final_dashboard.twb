      <aliases enabled='yes' />
      <column datatype='integer' name='[Age]' role='dimension' type='ordinal' />
      <column aggregate-role-from='[State]' caption='state_name' datatype='string' name='[Calculation_0430227848519683]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [State]&#13;&#10;    WHEN &apos;CA&apos; THEN &apos;California&apos;&#13;&#10;    WHEN &apos;CO&apos; THEN &apos;Colorado&apos;&#13;&#10;    WHEN &apos;FL&apos; THEN &apos;Florida&apos;&#13;&#10;    WHEN &apos;IL&apos; THEN &apos;Illinois&apos;&#13;&#10;    WHEN &apos;MI&apos; THEN &apos;Michigan&apos;&#13;&#10;    WHEN &apos;NY&apos; THEN &apos;New York&apos;&#13;&#10;    WHEN &apos;OR&apos; THEN &apos;Oregon&apos;&#13;&#10;    WHEN &apos;TX&apos; THEN &apos;Texas&apos;&#13;&#10;    WHEN &apos;WA&apos; THEN &apos;Washington&apos;&#13;&#10;    ELSE [State]&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_0430227850764292]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt; 18 THEN &quot;Under 18&quot;&#13;&#10;ELSEIF [Age] &lt;= 24 THEN &quot;18-24&quot;&#13;&#10;ELSEIF [Age] &lt;= 34 THEN &quot;25-34&quot;&#13;&#10;ELSEIF [Age] &lt;= 44 THEN &quot;35-44&quot;&#13;&#10;ELSEIF [Age] &lt;= 54 THEN &quot;45-54&quot;&#13;&#10;ELSEIF [Age] &lt;= 64 THEN &quot;55-64&quot;&#13;&#10;ELSE &quot;65+&quot;&#13;&#10;END' />
      </column>
      <column caption='product profit' datatype='real' name='[Calculation_0430227925901317]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Price]-[Cost_Price]' />
      </column>
      <column caption='Gender.' datatype='string' name='[Calculation_0665523487469568]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Gender]=&apos;M&apos; THEN &apos;Male&apos;&#13;&#10;else &apos;Female&apos;&#13;&#10;END' />
      </column>
      <column caption='bar chart visability' datatype='boolean' name='[Calculation_0665523535052801]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 2]=&apos;Yes&apos;' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_1653159142006786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity]*([Price]-[Discount])' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_1653159143440388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Quantity] * ([Cost_Price])' />
      </column>
      <column caption='Gross Profit' datatype='real' name='[Calculation_1653159143706629]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1653159142006786]- [Calculation_1653159143440388]' />
      </column>
      <column caption='Profit Margin %' datatype='real' name='[Calculation_1653159143993350]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1653159143706629]) / SUM([Calculation_1653159142006786])' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
      <column caption='Contact Email' datatype='string' name='[Contact_Email]' role='dimension' type='nominal' />
      <column caption='Contact Person' datatype='string' name='[Contact_Person]' role='dimension' type='nominal' />
      <column caption='Cost Price' datatype='real' name='[Cost_Price]' role='measure' type='quantitative' />
      <column caption='Customer ID' datatype='string' name='[Customer_ID]' role='dimension' type='nominal' />
      <column datatype='string' name='[Gender]' role='dimension' type='nominal' />
      <column caption='Product ID' datatype='string' name='[Product_ID]' role='dimension' type='nominal' />
      <column caption='Product Name' datatype='string' name='[Product_Name]' role='dimension' type='nominal' />
      <column datatype='string' name='[Region]' role='dimension' semantic-role='[Country].[Name]' type='nominal' />
